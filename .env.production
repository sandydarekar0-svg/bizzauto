# Server Configuration
PORT=4000
NODE_ENV=production

# Database (Update with your production database URL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/whatsapp_saas

# JWT Secrets (Generate strong random strings for production)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters-long
JWT_REFRESH_EXPIRES_IN=30d

# Encryption Key (32 bytes hex string for AES-256)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# CORS (Update with your production domain)
CORS_ORIGIN=https://yourdomain.com

# AI Providers (Get from respective dashboards)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here

# WhatsApp Business API (Meta Developer Portal)
META_APP_ID=your-meta-app-id-number
META_APP_SECRET=your-meta-app-secret-string
WHATSAPP_REDIRECT_URL=https://yourdomain.com/api/whatsapp/callback
WHATSAPP_API_VERSION=v18.0

# Razorpay (for payments - India)
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# Redis (for queues and caching)
REDIS_URL=redis://localhost:6379

# File Storage (MinIO)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=uploads

# Email (optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Logging
LOG_LEVEL=info

# n8n Automation (optional)
N8N_URL=http://n8n:5678
N8N_PASSWORD=your-n8n-admin-password
