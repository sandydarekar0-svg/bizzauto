{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start": "npx prisma generate && (npx prisma db push --accept-data-loss 2>/dev/null || true) && node dist/server/index.js",
    "server": "tsx watch src/server/index.ts",
    "server:prod": "npx prisma generate && (npx prisma db push --accept-data-loss 2>/dev/null || true) && node dist/server/index.js",
    "worker": "tsx watch src/server/worker.ts",
    "worker:prod": "node dist/server/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\" \"npm run worker\""
  },
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.1",
    "clsx": "2.1.1",
    "compression": "^1.8.1",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "emoji-picker-react": "^4.18.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "https-proxy-agent": "^9.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "openai": "^6.33.0",
    "prisma": "^7.6.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "3.4.0",
    "tsx": "^4.21.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "^22.19.15",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "2.3.0"
  }
}
